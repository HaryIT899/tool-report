{
  "manifest_version": 3,
  "name": "Domain Abuse Reporter Helper",
  "version": "1.0.0",
  "description": "Auto-fill forms for domain abuse reporting",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://search.google.com/*",
    "https://safebrowsing.google.com/*",
    "https://reportcontent.google.com/*",
    "https://abuse.cloudflare.com/*",
    "https://abuse.radix.website/*",
    "https://2captcha.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/*",
        "https://search.google.com/search-console/report-spam*",
        "https://safebrowsing.google.com/safebrowsing/report_phish/*",
        "https://reportcontent.google.com/forms/*",
        "https://abuse.cloudflare.com/*",
        "https://abuse.radix.website/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Domain Abuse Reporter Helper"
  }
}
