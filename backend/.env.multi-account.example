# ============================================
# MULTI-ACCOUNT CONFIGURATION EXAMPLE
# ============================================
# Copy this to .env and adjust values

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/domain-abuse-report
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# JWT
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================
# CHROME PROFILES
# ============================================
# Directory where Chrome profiles are stored
# Each account gets a subdirectory: profiles/ACCOUNT_ID/
PROFILES_DIR=./profiles

# ============================================
# PUPPETEER SETTINGS
# ============================================
# Set to false for local development (see browser)
# Set to true for production (background)
PUPPETEER_HEADLESS=false

# Timeout for page loads (milliseconds)
PUPPETEER_TIMEOUT=60000

# Optional: Path to Chrome executable
# Leave empty to use puppeteer's bundled Chromium
PUPPETEER_EXECUTABLE_PATH=

# Use system Chrome (recommended for non-headless)
PUPPETEER_CHANNEL=chrome

# Random User Agent (optional, requires 'user-agents' package)
PUPPETEER_RANDOM_UA=false

# Custom User Agent (optional)
PUPPETEER_USER_AGENT=

# ============================================
# MULTI-ACCOUNT JOB SETTINGS
# ============================================
# Maximum retry attempts per account before giving up
ACCOUNT_MAX_RETRY=3

# Auto-submit forms (DANGEROUS - use only if you trust the logic)
# Set to false to require manual review + submit
AUTO_SUBMIT=false

# Google login wait time (milliseconds)
# How long to wait for user to manually login
GOOGLE_LOGIN_WAIT_MS=600000

# Close login tab after successful login
CLOSE_LOGIN_TAB=false

# ============================================
# ACCOUNT ENCRYPTION
# ============================================
# 32-byte encryption key for storing account passwords
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCOUNTS_CRYPTO_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================
# EXTENSION PAYLOAD FIELDS
# ============================================
# These values are encoded into the payload sent to the extension
# The extension will use these to fill forms

# --- DMCA Forms (Google) ---
DMCA_FIRST_NAME=John
DMCA_LAST_NAME=Doe
DMCA_COMPANY=Example Inc
DMCA_EMAIL=dmca@example.com
DMCA_AUTHORIZED_URL=https://example.com
DMCA_WORK_DESCRIPTION=Original content created by our team

# --- Cloudflare Forms ---
CF_NAME=John Doe
CF_TITLE=Manager
CF_COMPANY=Example Inc
CF_TELE=+1234567890

# --- Radix Forms ---
RADIX_NAME=John Doe

# ============================================
# REPORT FILTERING (Optional)
# ============================================
# Only report to specific services (leave empty for all)
# Use URL fragments or service names

# Only report to services matching these URLs
REPORT_ONLY_SERVICE_URL=

# Only report to services matching these names
REPORT_ONLY_SERVICE_NAME=

# Exclude services matching these URLs
REPORT_EXCLUDE_SERVICE_URL=

# Exclude services matching these names
REPORT_EXCLUDE_SERVICE_NAME=

# ============================================
# PRODUCTION SETTINGS
# ============================================
# Uncomment and adjust for production

# Port
# PORT=3000

# CORS
# CORS_ORIGIN=https://yourdomain.com

# Logging
# LOG_LEVEL=info

# ============================================
# EXAMPLE MULTI-ACCOUNT SETUP
# ============================================
#
# 1. Create accounts in database:
#    - account1@gmail.com → Profile: ./profiles/507f1f77bcf86cd799439011/
#    - account2@gmail.com → Profile: ./profiles/507f1f77bcf86cd799439012/
#    - account3@gmail.com → Profile: ./profiles/507f1f77bcf86cd799439013/
#
# 2. Install extension in each profile:
#    - Open Chrome with profile: chrome --user-data-dir="./profiles/ACCOUNT_ID"
#    - Go to chrome://extensions/
#    - Load unpacked: select chrome-extension folder
#    - Extension persists in profile
#
# 3. Login each account:
#    - Open Chrome with profile
#    - Go to myaccount.google.com
#    - Login manually
#    - Session is saved in profile
#
# 4. Trigger reports:
#    - Via API: POST /reports/trigger { accountId, domainId, serviceIds }
#    - Via CLI: npm run trigger -- --account=account1@gmail.com --domain=evil.com --services=all
#
# 5. Monitor:
#    - Queue stats: GET /reports/queue-stats
#    - Account usage: GET /accounts
#    - Report logs: GET /report-logs
#
# ============================================
# TROUBLESHOOTING
# ============================================
#
# Problem: Extension not detecting payload
# Solution: Check extension is installed, check console logs
#
# Problem: Account status NEED_RELOGIN
# Solution: Re-login manually or provide password for auto-login
#
# Problem: Jobs stuck in queue
# Solution: Check Redis, check worker logs, resume queue
#
# Problem: Chrome profile conflicts
# Solution: Close all Chrome instances, check zombie processes
#
# See MULTI_ACCOUNT_GUIDE.md for complete troubleshooting guide
